<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Android 12+ splash screen (windowSplashScreen* attributes).
        - windowSplashScreenAnimatedIcon: use the adaptive-icon foreground so no
          white rounded-rect container is added by the system.
        - windowSplashScreenIconBackgroundColor: set to the same cream as the
          splash background so the mandatory icon circle is invisible.
        - windowBackground: keep the legacy drawable for the brief pre-render
          window flash on older embedding paths.
    -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowSplashScreenBackground">@color/splash_background</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@color/splash_background</item>
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
</resources>
